---
import { WompiClient } from "@pulgueta/wompi";
import { checkRateLimit, json, readCredentials } from "../../../lib/server";

export const prerender = false;

if (Astro.request.method !== "GET") {
  return json({ ok: false, error: "Method not allowed." }, 405);
}
const request = Astro.request;
const url = Astro.url;
  const limited = await checkRateLimit(request, "transaction");
  if (limited) return limited;

  const credentials = readCredentials(["WOMPI_PUBLIC_KEY"]);
  if (!credentials.ok) return credentials.response;

  const id = url.searchParams.get("id")?.trim();
  if (!id) return json({ ok: false, error: "Pass the transaction id as `?id=`." }, 400);

  const wompi = new WompiClient({ publicKey: credentials.publicKey, sandbox: true });
  const [error, transaction] = await wompi.transactions.getTransaction(id);
  if (error) {
    const notFound = "type" in error && error.type === "NOT_FOUND_ERROR";
    return json({ ok: false, error: error.message }, notFound ? 404 : 502);
  }

  return json({
    ok: true,
    configured: true,
    transaction: {
      id: transaction.id,
      status: transaction.status,
      reference: transaction.reference,
      amountInCents: transaction.amount_in_cents ?? null,
      paymentMethodType: transaction.payment_method_type ?? null,
      statusMessage: transaction.status_message ?? null,
    },
  });
---
