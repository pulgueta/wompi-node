{
  "name": "@pulgueta/wompi",
  "version": "3.1.0",
  "description": "El SDK de Wompi para Node.js",
  "author": "Andrés Rodríguez <roariasaf@gmail.com>",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pulgueta/wompi-node"
  },
  "bugs": {
    "url": "https://github.com/pulgueta/wompi-node/issues"
  },
  "homepage": "https://github.com/pulgueta/wompi-node",
  "files": [
    "dist",
    "skills"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js",
      "require": "./dist/schemas.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest --typecheck",
    "test:cov": "vitest run --typecheck --coverage"
  },
  "keywords": [
    "wompi",
    "sdk",
    "wompi-sdk",
    "wompi-node-sdk",
    "bancolombia",
    "pagos",
    "pagos-bancolombia"
  ],
  "devDependencies": {
    "@pulgueta/wompi-tsconfig": "workspace:*",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^4.1.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "zod": "^4.3.6"
  }
}
