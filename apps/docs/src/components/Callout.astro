---
import Icon from "./Icon.astro";

interface Props {
  type?: "note" | "tip" | "warning" | "danger";
  title?: string;
}

const { type = "note", title } = Astro.props;

const variants = {
  note: {
    icon: "info" as const,
    label: "Note",
    box: "border-border bg-muted/40",
    accent: "text-foreground",
  },
  tip: {
    icon: "check-circle" as const,
    label: "Tip",
    box: "border-primary/30 bg-primary/5",
    accent: "text-primary",
  },
  warning: {
    icon: "warning" as const,
    label: "Warning",
    box: "border-amber-500/30 bg-amber-500/10",
    accent: "text-amber-600 dark:text-amber-500",
  },
  danger: {
    icon: "warning" as const,
    label: "Caution",
    box: "border-destructive/30 bg-destructive/10",
    accent: "text-destructive",
  },
};

const variant = variants[type];
---

<aside class:list={['callout rounded-lg border p-4', variant.box]}>
  <div class="flex items-center gap-2">
    <Icon name={variant.icon} class:list={['size-4 shrink-0', variant.accent]} />
    <p class:list={['font-heading text-sm font-semibold', variant.accent]}>
      {title ?? variant.label}
    </p>
  </div>
  <div class="callout-body mt-1.5 text-sm text-muted-foreground">
    <slot />
  </div>
</aside>

<style>
  .callout-body > :global(* + *) {
    margin-top: 0.5rem;
  }
  .callout-body :global(a) {
    color: var(--primary);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .callout-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.05rem 0.3rem;
  }
</style>
