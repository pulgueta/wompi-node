---
import { Code } from "astro:components";
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import InstallTabs from "../components/InstallTabs.astro";
import { site } from "../config/site";

const heroSnippet = `import { WompiClient } from "@pulgueta/wompi";

const wompi = new WompiClient({
  publicKey: process.env.WOMPI_PUBLIC_KEY!,
  privateKey: process.env.WOMPI_PRIVATE_KEY,
  sandbox: true,
});

const [error, response] = await wompi.transactions.getTransaction("txn_123");
if (error) {
  // error is typed — branch on error.type or instanceof
  return;
}

response.data.status; // "APPROVED" | "PENDING" | "DECLINED" | ...`;

const liveExampleSnippet = `const wompi = new WompiClient({
  publicKey: WOMPI_PUBLIC_KEY,
  privateKey: WOMPI_PRIVATE_KEY,
  sandbox: true,
});

const [error, response] = await wompi.paymentLinks.createPaymentLink({
  name: "Order #1024",
  description: "Thank you for shopping.",
  single_use: true,
  collect_shipping: false,
  amount_in_cents: 99_000,
  currency: "COP",
});

if (error) return new Response(error.message, { status: 422 });
return Response.json({ url: response.data.checkout_url });`;

const features = [
  {
    icon: "shield" as const,
    title: "Error-first results",
    body: "Every call returns a [error, data] tuple, so you can never forget to handle a failure. Errors are typed subclasses, not stringly-typed.",
  },
  {
    icon: "sparkle" as const,
    title: "Validated with Zod",
    body: "Inputs are parsed before they hit the wire and responses are parsed leniently — unknown fields pass through, identities are typed.",
  },
  {
    icon: "package" as const,
    title: "Tree-shakeable subpaths",
    body: "Import only what you use: client, schemas, types, errors and a server entry for the integrity signature helper.",
  },
  {
    icon: "bolt" as const,
    title: "Sandbox by default",
    body: "Flip a single flag to switch between sandbox and production. Tests, demos and integration suites stay safe by default.",
  },
  {
    icon: "credit-card" as const,
    title: "Full payment surface",
    body: "Transactions, tokens, payment sources, payment links and PSE financial institutions — everything documented and typed.",
  },
  {
    icon: "code" as const,
    title: "Zero runtime deps",
    body: "Uses the platform fetch and Web Crypto. Works on Node 22+, edge runtimes and modern serverless platforms out of the box.",
  },
];
---

<BaseLayout title={`${site.shortName} — ${site.tagline}`} description={site.description} exactTitle>
  <Header />

  <main>
    <section class="border-b border-border">
      <div class="mx-auto max-w-360 px-6 py-20 sm:px-8 sm:py-24 lg:py-28">
        <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_1fr] lg:gap-16">
          <div>
            <a
              href={site.repo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full border border-border bg-muted/50 px-3 py-1 font-mono text-xs text-muted-foreground transition-colors hover:border-primary/40 hover:text-foreground"
            >
              <span class="inline-block size-1.5 rounded-full bg-primary"></span>
              v{site.version} — read the changelog on GitHub
              <Icon name="arrow-right" class="size-3" />
            </a>

            <h1
              class="font-heading mt-6 text-4xl font-bold tracking-tight sm:text-5xl lg:text-[3.5rem] lg:leading-[1.05]"
            >
              The unofficial Wompi SDK for{" "}
              <span class="text-primary">Node.js</span>
            </h1>

            <p class="mt-6 max-w-xl text-base leading-relaxed text-muted-foreground sm:text-lg">
              A fully typed, error-first SDK for the Wompi payments API. Validated with Zod,
              tree-shakeable across subpath exports, and built for transactions, tokens, payment
              sources, payment links and PSE.
            </p>

            <div class="mt-8 flex flex-wrap items-center gap-3">
              <a
                href="/docs/quickstart"
                class="inline-flex h-10 items-center gap-1.5 rounded-md bg-primary px-5 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90 focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
              >
                Get started
                <Icon name="arrow-right" class="size-4" />
              </a>
              <a
                href="/docs/introduction"
                class="inline-flex h-10 items-center rounded-md border border-border bg-background px-5 text-sm font-medium text-foreground transition-colors hover:bg-muted focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
              >
                Read the docs
              </a>
              <a
                href={site.repo}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex h-10 items-center gap-1.5 rounded-md px-3 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
              >
                <Icon name="github" class="size-4" />
                Star on GitHub
              </a>
            </div>

            <div class="mt-8 max-w-md">
              <InstallTabs pkg="@pulgueta/wompi" />
            </div>
          </div>

          <figure
            class="code-block overflow-hidden rounded-xl border border-border bg-background shadow-sm"
          >
            <figcaption
              class="flex items-center justify-between border-b border-border bg-muted/60 py-1.5 pr-1.5 pl-3"
            >
              <span class="font-mono text-xs text-muted-foreground">example.ts</span>
              <span class="font-mono text-[10px] tracking-wide text-muted-foreground uppercase"
                >TypeScript</span
              >
            </figcaption>
            <Code
              code={heroSnippet}
              lang="ts"
              themes={{ light: "github-light", dark: "github-dark" }}
            />
          </figure>
        </div>
      </div>
    </section>

    <section class="border-b border-border bg-muted/20">
      <div class="mx-auto max-w-[90rem] px-6 py-20 sm:px-8 lg:py-24">
        <div class="mx-auto max-w-2xl text-center">
          <p class="font-heading text-sm font-semibold text-primary">Why this SDK</p>
          <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">
            Built for the way you actually call payment APIs
          </h2>
          <p class="mt-4 text-muted-foreground sm:text-lg">
            Error-first results, validated inputs, typed responses and zero runtime dependencies —
            so adding payments to your app feels like calling any other typed service.
          </p>
        </div>

        <ul class="mt-12 grid gap-px overflow-hidden rounded-xl border border-border sm:grid-cols-2 lg:grid-cols-3">
          {
            features.map((feature) => (
              <li class="flex flex-col gap-3 bg-background p-6">
                <span class="inline-grid size-9 place-items-center rounded-md bg-primary/10 text-primary">
                  <Icon name={feature.icon} class="size-[18px]" />
                </span>
                <p class="font-heading text-base font-semibold">{feature.title}</p>
                <p class="text-sm leading-relaxed text-muted-foreground">{feature.body}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="border-b border-border">
      <div class="mx-auto max-w-[90rem] px-6 py-20 sm:px-8 lg:py-24">
        <div class="grid gap-12 lg:grid-cols-[1fr_1.05fr] lg:items-center lg:gap-16">
          <div>
            <p class="font-heading text-sm font-semibold text-primary">Live in this site</p>
            <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">
              Real Astro API routes, calling the real Wompi sandbox
            </h2>
            <p class="mt-4 text-muted-foreground sm:text-lg">
              Two interactive demos render the SDK end-to-end: a card checkout that signs the
              transaction with the integrity key, and a hosted payment link that returns a checkout
              URL you can open right away.
            </p>
            <div class="mt-6 flex flex-wrap gap-3">
              <a
                href="/docs/examples/card-checkout"
                class="inline-flex h-10 items-center gap-1.5 rounded-md border border-border bg-background px-4 text-sm font-medium transition-colors hover:bg-muted"
              >
                <Icon name="credit-card" class="size-4" />
                Card checkout
              </a>
              <a
                href="/docs/examples/payment-link"
                class="inline-flex h-10 items-center gap-1.5 rounded-md border border-border bg-background px-4 text-sm font-medium transition-colors hover:bg-muted"
              >
                <Icon name="link" class="size-4" />
                Payment link
              </a>
            </div>
          </div>

          <figure class="code-block overflow-hidden rounded-xl border border-border">
            <figcaption
              class="flex items-center justify-between border-b border-border bg-muted/60 py-1.5 pr-1.5 pl-3"
            >
              <span class="font-mono text-xs text-muted-foreground"
                >src/pages/api/examples/payment-link.ts</span
              >
            </figcaption>
            <Code
              code={liveExampleSnippet}
              lang="ts"
              themes={{ light: "github-light", dark: "github-dark" }}
            />
          </figure>
        </div>
      </div>
    </section>

    <section>
      <div class="mx-auto max-w-[90rem] px-6 py-20 sm:px-8 lg:py-24">
        <div
          class="flex flex-col items-start gap-6 rounded-xl border border-border bg-muted/30 p-8 sm:flex-row sm:items-center sm:justify-between sm:p-10"
        >
          <div>
            <h2 class="font-heading text-2xl font-bold tracking-tight">Ready to ship?</h2>
            <p class="mt-2 max-w-xl text-muted-foreground">
              Install the SDK, drop your sandbox keys in and follow the five-minute quickstart.
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a
              href="/docs/quickstart"
              class="inline-flex h-10 items-center gap-1.5 rounded-md bg-primary px-5 text-sm font-medium text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
            >
              Quickstart
              <Icon name="arrow-right" class="size-4" />
            </a>
            <a
              href={site.npm}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-10 items-center gap-1.5 rounded-md border border-border bg-background px-4 text-sm font-medium transition-colors hover:bg-muted"
            >
              <Icon name="package" class="size-4" />
              View on npm
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
