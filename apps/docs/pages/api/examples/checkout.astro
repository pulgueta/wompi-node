---
import { WompiClient } from "@pulgueta/wompi";
import { getSignatureKey } from "@pulgueta/wompi/server";
import { checkRateLimit, json, readCredentials } from "../../../lib/server";

export const prerender = false;

if (Astro.request.method !== "POST") {
  return json({ ok: false, error: "Method not allowed." }, 405);
}
const request = Astro.request;
  const limited = await checkRateLimit(request, "checkout");
  if (limited) return limited;

  const credentials = readCredentials(["WOMPI_PUBLIC_KEY", "WOMPI_INTEGRITY_KEY"]);
  if (!credentials.ok) return credentials.response;

  let body: Record<string, unknown>;
  try {
    body = (await request.json()) as Record<string, unknown>;
  } catch {
    return json({ ok: false, error: "Request body must be valid JSON." }, 400);
  }

  const card = body.card as Record<string, string> | undefined;
  const customerEmail = String(body.customerEmail ?? "").trim();
  const amountInCents = Number(body.amountInCents);
  const installments = Number(body.installments) || 1;
  if (!card || !customerEmail || !Number.isInteger(amountInCents) || amountInCents < 1) {
    return json(
      { ok: false, error: "A card, customer email, and whole `amountInCents` are required." },
      400
    );
  }

  const wompi = new WompiClient({ publicKey: credentials.publicKey, sandbox: true });
  const [merchantError, merchant] = await wompi.merchants.getMerchant();
  if (merchantError) return json({ ok: false, step: "merchant", error: merchantError.message }, 502);

  const acceptanceToken = merchant.presigned_acceptance?.acceptance_token;
  if (!acceptanceToken) {
    return json({ ok: false, step: "merchant", error: "Merchant has no acceptance token." }, 502);
  }

  const [tokenError, token] = await wompi.tokens.tokenizeCard(card);
  if (tokenError) return json({ ok: false, step: "tokenize", error: tokenError.message }, 422);

  const reference = `docs-demo-${Date.now()}`;
  const signature = await getSignatureKey({
    reference,
    amountInCents,
    integrityKey: credentials.integrityKey!,
  });
  const [transactionError, transaction] = await wompi.transactions.createTransaction({
    acceptance_token: acceptanceToken,
    amount_in_cents: amountInCents,
    currency: "COP",
    signature,
    customer_email: customerEmail,
    reference,
    payment_method: { type: "CARD", token: token.id, installments },
  });
  if (transactionError) {
    return json({ ok: false, step: "transaction", error: transactionError.message }, 422);
  }

  return json({
    ok: true,
    configured: true,
    transaction: {
      id: transaction.id,
      status: transaction.status,
      reference: transaction.reference,
      amountInCents: transaction.amount_in_cents ?? amountInCents,
      paymentMethodType: transaction.payment_method_type ?? "CARD",
      statusMessage: transaction.status_message ?? null,
      createdAt: transaction.created_at ?? null,
    },
    card: { brand: token.brand ?? null, lastFour: token.last_four ?? null },
  });
---
