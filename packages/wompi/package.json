{
  "name": "@pulgueta/wompi",
  "version": "0.0.0",
  "description": "Wompi SDK for Node.js and the browser",
  "author": "Andrés Rodríguez <roariasaf@gmail.com>",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pulgueta/wompi-sdk"
  },
  "bugs": {
    "url": "https://github.com/pulgueta/wompi-sdk/issues"
  },
  "homepage": "https://github.com/pulgueta/wompi-sdk",
  "files": ["dist"],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:cov": "vitest run --coverage",
    "release": "pnpm publish --no-git-check"
  },
  "keywords": [
    "wompi",
    "sdk",
    "payments",
    "colombia",
    "bancolombia"
  ],
  "devDependencies": {
    "@pulgueta/wompi-tsconfig": "workspace:*",
    "@types/node": "^22.5.5",
    "@vitest/coverage-v8": "^2.1.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
