{
  "name": "@pulgueta/wompi-react",
  "version": "0.0.0",
  "description": "React hooks for Wompi payment integration",
  "author": "Andrés Rodríguez <roariasaf@gmail.com>",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pulgueta/wompi-sdk",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/pulgueta/wompi-sdk/issues"
  },
  "homepage": "https://github.com/pulgueta/wompi-sdk",
  "files": ["dist"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "keywords": [
    "wompi",
    "react",
    "hooks",
    "react-hooks",
    "payment",
    "wompi-react",
    "bancolombia",
    "pse"
  ],
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@pulgueta/wompi": "workspace:*"
  },
  "devDependencies": {
    "@pulgueta/wompi-tsconfig": "workspace:*",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.12",
    "@vitest/coverage-v8": "^2.1.1",
    "react": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
