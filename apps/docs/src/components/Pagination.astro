---
import { getPagination } from "../config/nav";
import Icon from "./Icon.astro";

const { prev, next } = getPagination(Astro.url.pathname);
---

<nav class="mt-16 grid gap-3 border-t border-border pt-8 sm:grid-cols-2" aria-label="Pagination">
  {
    prev ? (
      <a
        href={prev.href}
        class="group flex flex-col gap-1 rounded-lg border border-border p-4 transition-colors hover:border-primary/40 hover:bg-muted/50"
      >
        <span class="flex items-center gap-1 text-xs text-muted-foreground">
          <Icon name="arrow-left" class="size-3.5" />
          Previous
        </span>
        <span class="font-heading font-medium text-foreground group-hover:text-primary">
          {prev.title}
        </span>
      </a>
    ) : (
      <div />
    )
  }
  {
    next ? (
      <a
        href={next.href}
        class="group flex flex-col items-end gap-1 rounded-lg border border-border p-4 text-right transition-colors hover:border-primary/40 hover:bg-muted/50 sm:col-start-2"
      >
        <span class="flex items-center gap-1 text-xs text-muted-foreground">
          Next
          <Icon name="arrow-right" class="size-3.5" />
        </span>
        <span class="font-heading font-medium text-foreground group-hover:text-primary">
          {next.title}
        </span>
      </a>
    ) : (
      <div />
    )
  }
</nav>
