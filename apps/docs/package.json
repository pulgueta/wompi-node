{
  "name": "docs",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "blume dev --host",
    "build": "pnpm format:check && blume check --strict && blume validate --strict && blume build --strict --analyze --budget-js 4000 --budget-css 130",
    "check": "blume check --strict",
    "validate": "blume validate --strict",
    "doctor": "blume doctor",
    "format:check": "prettier --check 'content/**/*.mdx'",
    "preview": "blume preview"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@shikijs/twoslash": "^4.3.1",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^7.0.2",
    "blume": "1.0.3"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  }
}
