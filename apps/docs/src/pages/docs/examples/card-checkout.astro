---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import CodeBlock from "../../../components/CodeBlock.astro";
import Callout from "../../../components/Callout.astro";
import Badge from "../../../components/Badge.astro";
import { CardCheckoutForm } from "../../../components/examples/CardCheckoutForm";

const apiRoute = `import type { APIRoute } from "astro";
import { WompiClient } from "@pulgueta/wompi";
import { getSignatureKey } from "@pulgueta/wompi/server";
import { WOMPI_PUBLIC_KEY, WOMPI_PRIVATE_KEY, WOMPI_INTEGRITY_KEY } from "astro:env/server";

export const prerender = false;

export const POST: APIRoute = async ({ request }) => {
  const { card, customerEmail, amountInCents } = await request.json();

  const wompi = new WompiClient({
    publicKey: WOMPI_PUBLIC_KEY,
    privateKey: WOMPI_PRIVATE_KEY,
    sandbox: true,
  });

  // 1. Fetch the acceptance token.
  const [merchantError, merchant] = await wompi.merchants.getMerchant();
  if (merchantError) return Response.json({ error: merchantError.message }, { status: 502 });

  // 2. Tokenize the card.
  const [tokenError, token] = await wompi.tokens.tokenizeCard(card);
  if (tokenError) return Response.json({ error: tokenError.message }, { status: 422 });

  // 3. Sign the amount.
  const reference = \`docs-demo-\${Date.now()}\`;
  const signature = await getSignatureKey({
    reference,
    amountInCents,
    integrityKey: WOMPI_INTEGRITY_KEY,
  });

  // 4. Create the transaction.
  const [transactionError, transaction] = await wompi.transactions.createTransaction({
    acceptance_token: merchant.data.presigned_acceptance!.acceptance_token,
    amount_in_cents: amountInCents,
    currency: "COP",
    signature,
    customer_email: customerEmail,
    reference,
    payment_method: { type: "CARD", token: token.data.id, installments: 1 },
  });

  if (transactionError) return Response.json({ error: transactionError.message }, { status: 422 });
  return Response.json({ transaction: transaction.data });
};`;
---

<DocsLayout
  section="Examples"
  title="Card checkout"
  description="A live Astro API route that tokenizes a card, signs the amount and creates a Wompi sandbox transaction."
>
  <p>
    <Badge variant="default">Live</Badge>
    The form below calls the same SDK methods you'd use in production. The API route lives in
    <code>apps/docs/src/pages/api/examples/checkout.ts</code> and runs on every request — set
    <code>WOMPI_PUBLIC_KEY</code>, <code>WOMPI_PRIVATE_KEY</code> and
    <code>WOMPI_INTEGRITY_KEY</code> in <code>apps/docs/.env</code> to charge a real sandbox card.
  </p>

  <Callout type="note" title="Sandbox only">
    The route hard-codes <code>sandbox: true</code>. <code>4242 4242 4242 4242</code> is approved;
    <code>4111 1111 1111 1111</code> is declined.
  </Callout>

  <h2 id="try-it">Try it</h2>
  <div class="not-prose my-6">
    <CardCheckoutForm client:load />
  </div>

  <h2 id="api-route">The API route</h2>
  <p>
    Four steps — fetch the acceptance token, tokenize the card, sign the amount, create the
    transaction. Every error branch returns a JSON body with the SDK's own error message.
  </p>

  <CodeBlock code={apiRoute} lang="ts" filename="src/pages/api/examples/checkout.ts" />

  <h2 id="environment">Environment variables</h2>
  <p>
    The route is declared with Astro's <code>envField</code> in <code>astro.config.mjs</code>, so
    Vercel's environment is type-checked at build time:
  </p>

  <CodeBlock
    code={`env: {
  schema: {
    WOMPI_PUBLIC_KEY: envField.string({ context: "server", access: "secret", optional: true }),
    WOMPI_PRIVATE_KEY: envField.string({ context: "server", access: "secret", optional: true }),
    WOMPI_INTEGRITY_KEY: envField.string({ context: "server", access: "secret", optional: true }),
  },
}`}
    lang="js"
    filename="astro.config.mjs"
  />

  <p>
    The keys are <code>optional: true</code> on purpose — the site always builds, and the route
    returns a friendly notice when a key is missing instead of crashing the request.
  </p>
</DocsLayout>
