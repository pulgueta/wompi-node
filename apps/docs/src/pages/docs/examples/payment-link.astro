---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import CodeBlock from "../../../components/CodeBlock.astro";
import Callout from "../../../components/Callout.astro";
import Badge from "../../../components/Badge.astro";
import { PaymentLinkForm } from "../../../components/examples/PaymentLinkForm";

const apiRoute = `import type { APIRoute } from "astro";
import { WompiClient } from "@pulgueta/wompi";
import { WOMPI_PUBLIC_KEY, WOMPI_PRIVATE_KEY } from "astro:env/server";

export const prerender = false;

export const POST: APIRoute = async ({ request }) => {
  const { name, description, amountInCents, singleUse, collectShipping } = await request.json();

  const wompi = new WompiClient({
    publicKey: WOMPI_PUBLIC_KEY,
    privateKey: WOMPI_PRIVATE_KEY,
    sandbox: true,
  });

  const [error, response] = await wompi.paymentLinks.createPaymentLink({
    name,
    description,
    single_use: singleUse,
    collect_shipping: collectShipping,
    amount_in_cents: amountInCents,
    currency: "COP",
  });

  if (error) return Response.json({ error: error.message }, { status: 422 });

  const link = response.data;
  return Response.json({
    paymentLink: {
      id: link.id,
      url: link.checkout_url,
      name: link.name ?? name,
      amountInCents: link.amount_in_cents ?? amountInCents,
      singleUse: link.single_use ?? singleUse,
    },
  });
};`;

const followUpSnippet = `// After the customer pays, the resulting transaction carries the link's id.
const [error, response] = await wompi.transactions.listTransactions({
  payment_method_type: "CARD",
  from_date: "2026-01-01",
  until_date: "2026-12-31",
});

const paidByLink = response?.data.filter((t) => t.payment_link_id === link.id) ?? [];`;
---

<DocsLayout
  section="Examples"
  title="Payment link"
  description="A live Astro API route that creates a hosted Wompi checkout link and returns its public URL."
>
  <p>
    <Badge variant="default">Live</Badge>
    Generate a hosted checkout link without ever touching card details. Submit the
    form to call
    <code>POST /api/examples/payment-link</code>, which proxies to
    <code>wompi.paymentLinks.createPaymentLink</code> and returns the public URL.
  </p>

  <Callout type="note" title="Try the URL right away">
    The link the demo returns is a real sandbox link — you can open it and run
    through the hosted checkout end-to-end.
  </Callout>

  <h2 id="try-it">Try it</h2>
  <div class="not-prose my-6">
    <PaymentLinkForm client:load />
  </div>

  <h2 id="api-route">The API route</h2>
  <p>
    The route is intentionally tiny: a single SDK call, two branches, no
    integrity signature handshake. Wompi computes the signature server-side when
    you create the link.
  </p>

  <CodeBlock
    code={apiRoute}
    lang="ts"
    filename="src/pages/api/examples/payment-link.ts"
  />

  <h2 id="following-up">Reconciling paid links</h2>
  <p>
    Each transaction Wompi creates against a hosted link carries the link's id
    under
    <code>payment_link_id</code>. List or filter transactions to reconcile the
    link against the payment.
  </p>

  <CodeBlock code={followUpSnippet} lang="ts" />

  <Callout type="tip" title="Single-use vs reusable">
    A <code>single_use: true</code> link burns after one paid transaction. Leave it
    <code>false</code> when you want a recurring "donate" / "tip jar" URL.
  </Callout>
</DocsLayout>
