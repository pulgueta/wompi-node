---
import { Code } from "astro:components";
import Icon from "./Icon.astro";

interface Props {
  /** Package name(s) to install, e.g. `"@pulgueta/wompi zod"`. */
  pkg: string;
}

const { pkg } = Astro.props;

const managers = [
  { id: "pnpm", label: "pnpm", cmd: `pnpm add ${pkg}` },
  { id: "npm", label: "npm", cmd: `npm install ${pkg}` },
  { id: "yarn", label: "yarn", cmd: `yarn add ${pkg}` },
  { id: "bun", label: "bun", cmd: `bun add ${pkg}` },
];
---

<div class="install-tabs overflow-hidden rounded-lg border border-border">
  <div role="tablist" aria-label="Package manager" class="flex border-b border-border bg-muted/60">
    {
      managers.map((manager, index) => (
        <button
          role="tab"
          type="button"
          data-tab={manager.id}
          aria-selected={index === 0 ? 'true' : 'false'}
          class="border-b-2 border-transparent px-3.5 py-2 font-mono text-xs text-muted-foreground transition-colors hover:text-foreground aria-selected:border-primary aria-selected:text-foreground"
        >
          {manager.label}
        </button>
      ))
    }
  </div>
  {
    managers.map((manager, index) => (
      <div
        role="tabpanel"
        data-panel={manager.id}
        class="code-block relative"
        hidden={index !== 0}
      >
        <button
          type="button"
          class="copy-btn absolute top-1.5 right-1.5 z-10 inline-grid size-7 place-items-center rounded-md text-muted-foreground transition-colors hover:bg-background hover:text-foreground"
          aria-label="Copy command"
        >
          <Icon name="copy" class="copy-icon size-3.5" />
          <Icon name="check" class="check-icon hidden size-3.5 text-primary" />
        </button>
        <Code
          code={manager.cmd}
          lang="bash"
          themes={{ light: 'github-light', dark: 'github-dark' }}
        />
      </div>
    ))
  }
</div>

<script>
  for (const tabs of document.querySelectorAll<HTMLElement>('.install-tabs')) {
    const buttons = [...tabs.querySelectorAll<HTMLButtonElement>('[role=tab]')];
    const panels = [...tabs.querySelectorAll<HTMLElement>('[role=tabpanel]')];

    for (const button of buttons) {
      button.addEventListener('click', () => {
        for (const other of buttons) {
          other.setAttribute('aria-selected', String(other === button));
        }
        for (const panel of panels) {
          panel.hidden = panel.dataset.panel !== button.dataset.tab;
        }
      });
    }
  }
</script>
