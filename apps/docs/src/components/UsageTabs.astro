---
import { Code } from "astro:components";
import Icon from "./Icon.astro";

/** One worked example: a sidebar entry on the left, a code panel on the right. */
export interface UsageExample {
  id: string;
  /** Sidebar label. */
  label: string;
  /** One-line descriptor shown under the label (desktop only). */
  description: string;
  /** Icon name — must exist in {@link Icon}. */
  icon: "credit-card" | "link" | "layers" | "bank" | "shield";
  /** Filename shown in the code panel header. */
  filename: string;
  code: string;
}

interface Props {
  examples: UsageExample[];
  /** Namespaces the tab/panel ids so multiple instances don't collide. */
  idBase?: string;
}

const { examples, idBase = "usage" } = Astro.props;
---

<div class="usage-tabs grid gap-3 lg:grid-cols-[17rem_minmax(0,1fr)] lg:gap-6">
  <div
    role="tablist"
    aria-orientation="vertical"
    aria-label="SDK usage examples"
    class="no-scrollbar -mx-6 flex gap-2 overflow-x-auto px-6 pb-1 sm:mx-0 sm:px-0 lg:flex-col lg:overflow-visible lg:pb-0"
  >
    {
      examples.map((example, index) => (
        <button
          role="tab"
          type="button"
          id={`${idBase}-tab-${example.id}`}
          data-tab={example.id}
          aria-selected={index === 0 ? 'true' : 'false'}
          aria-controls={`${idBase}-panel-${example.id}`}
          tabindex={index === 0 ? 0 : -1}
          class="group flex shrink-0 items-center gap-3 rounded-lg border border-transparent px-3.5 py-3 text-left transition-colors hover:bg-muted/60 aria-selected:border-border aria-selected:bg-muted lg:w-full"
        >
          <span class="inline-grid size-8 shrink-0 place-items-center rounded-md bg-muted text-muted-foreground transition-colors group-hover:text-foreground group-aria-selected:bg-primary/10 group-aria-selected:text-primary">
            <Icon name={example.icon} class="size-[18px]" />
          </span>
          <span class="min-w-0">
            <span class="block text-sm font-medium whitespace-nowrap text-muted-foreground transition-colors group-hover:text-foreground group-aria-selected:text-foreground lg:whitespace-normal">
              {example.label}
            </span>
            <span class="mt-0.5 hidden text-xs leading-snug text-muted-foreground lg:block">
              {example.description}
            </span>
          </span>
        </button>
      ))
    }
  </div>

  <div class="min-w-0">
    {
      examples.map((example, index) => (
        <figure
          role="tabpanel"
          id={`${idBase}-panel-${example.id}`}
          data-panel={example.id}
          aria-labelledby={`${idBase}-tab-${example.id}`}
          tabindex="0"
          hidden={index !== 0}
          class="code-block overflow-hidden rounded-xl border border-border bg-background focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
        >
          <figcaption class="flex items-center justify-between border-b border-border bg-muted/60 py-1.5 pr-1.5 pl-3">
            <span class="font-mono text-xs text-muted-foreground">{example.filename}</span>
            <button
              type="button"
              class="copy-btn inline-grid size-7 place-items-center rounded-md text-muted-foreground transition-colors hover:bg-background hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
              aria-label="Copy code to clipboard"
            >
              <Icon name="copy" class="copy-icon size-3.5" />
              <Icon name="check" class="check-icon hidden size-3.5 text-primary" />
            </button>
          </figcaption>
          <Code code={example.code} lang="ts" themes={{ light: 'github-light', dark: 'github-dark' }} />
        </figure>
      ))
    }
  </div>
</div>

<script>
  for (const tabs of document.querySelectorAll<HTMLElement>('.usage-tabs')) {
    const buttons = [...tabs.querySelectorAll<HTMLButtonElement>('[role=tab]')];
    const panels = [...tabs.querySelectorAll<HTMLElement>('[role=tabpanel]')];

    const select = (button: HTMLButtonElement) => {
      for (const other of buttons) {
        const active = other === button;
        other.setAttribute('aria-selected', String(active));
        other.tabIndex = active ? 0 : -1;
      }
      for (const panel of panels) {
        panel.hidden = panel.dataset.panel !== button.dataset.tab;
      }
    };

    buttons.forEach((button, index) => {
      button.addEventListener('click', () => select(button));
      button.addEventListener('keydown', (event) => {
        const last = buttons.length - 1;
        let next = -1;

        if (event.key === 'ArrowDown' || event.key === 'ArrowRight') next = index === last ? 0 : index + 1;
        else if (event.key === 'ArrowUp' || event.key === 'ArrowLeft') next = index === 0 ? last : index - 1;
        else if (event.key === 'Home') next = 0;
        else if (event.key === 'End') next = last;
        else return;

        event.preventDefault();
        buttons[next].focus();
        select(buttons[next]);
      });
    });
  }
</script>
