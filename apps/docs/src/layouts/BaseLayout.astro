---
import { ClientRouter } from "astro:transitions";
import { Analytics } from "@vercel/analytics/react";
import { SpeedInsights } from "@vercel/speed-insights/react";

import "../styles/global.css";
import { site } from "../config/site";

interface Props {
  title: string;
  description?: string;
  /** When true the title is used verbatim instead of being suffixed with the site name. */
  exactTitle?: boolean;
  noindex?: boolean;
}

const { title, description = site.description, exactTitle = false, noindex = false } = Astro.props;

const pageTitle = exactTitle ? title : `${title} — ${site.shortName}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).href;
const ogImage = new URL("/og-image.webp", Astro.site ?? site.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <meta name="generator" content={Astro.generator} />

    <!-- Client-side routing: animates page swaps with the View Transitions API. -->
    <ClientRouter />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}

    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0c1118" media="(prefers-color-scheme: dark)" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.shortName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image:width" content="8000" />
    <meta property="og:image:height" content="4500" />
    <meta property="og:image:alt" content={`${site.name} — ${site.tagline}`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${site.name} — ${site.tagline}`} />

    <!-- Apply the persisted theme before paint to avoid a flash of the wrong theme. -->
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('theme');
          const dark = stored
            ? stored === 'dark'
            : window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.classList.toggle('dark', dark);
        } catch {}
      })();
    </script>
  </head>
  <body class="min-h-dvh bg-background text-foreground antialiased">
    <slot />

    <Analytics />
    <SpeedInsights />

    <!--
      Theme system, made resilient to client-side navigation. The pre-paint
      script in <head> sets the initial class on first load; these document-level
      handlers keep it working as the router swaps pages:
        • a delegated click handler toggles + persists the theme (survives swaps);
        • astro:before-swap copies the live theme onto the incoming document so a
          navigation never flashes the wrong theme mid-transition.
    -->
    <script>
      const root = document.documentElement;

      document.addEventListener('click', (event) => {
        if (!(event.target as HTMLElement).closest('#theme-toggle')) return;
        const isDark = root.classList.toggle('dark');
        try {
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        } catch {}
      });

      document.addEventListener('astro:before-swap', (event) => {
        event.newDocument.documentElement.classList.toggle('dark', root.classList.contains('dark'));
      });
    </script>

    <!-- Delegated copy-to-clipboard handler for every `.copy-btn` on the page. -->
    <script>
      document.addEventListener('click', async (event) => {
        const button = (event.target as HTMLElement).closest('.copy-btn');
        if (!button) return;

        const block = button.closest('.code-block');
        const text = block?.querySelector('.astro-code')?.textContent ?? '';
        if (!text) return;

        try {
          await navigator.clipboard.writeText(text);
          const copyIcon = button.querySelector('.copy-icon');
          const checkIcon = button.querySelector('.check-icon');
          copyIcon?.classList.add('hidden');
          checkIcon?.classList.remove('hidden');
          setTimeout(() => {
            copyIcon?.classList.remove('hidden');
            checkIcon?.classList.add('hidden');
          }, 1600);
        } catch {
          /* Clipboard unavailable — silently ignore. */
        }
      });
    </script>
  </body>
</html>
